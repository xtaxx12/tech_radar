VITE_API_URL=http://localhost:4000
# Nota: el Client ID de Google OAuth se lee desde /auth/config (el backend es
# la única fuente de verdad). No hace falta duplicarlo aquí.

# Google Analytics 4 — opcional. Si lo dejás vacío, no se carga nada.
# Obtené el ID en https://analytics.google.com/ → Admin → Data Streams → Web
# El formato es "G-XXXXXXXXXX".
VITE_GA_MEASUREMENT_ID=
