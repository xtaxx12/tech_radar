PORT=4000
CORS_ORIGIN=http://localhost:5173
SYNC_INTERVAL_MINUTES=60

# Fuentes de datos (opcional, si no hay key se usa scraping público)
MEETUP_API_KEY=
EVENTBRITE_API_KEY=

# PostgreSQL — valor por defecto matchea docker-compose.yml (postgres:postgres@localhost:5434)
# Otros ejemplos:
#   Neon:     postgres://user:pass@ep-xxx.neon.tech/tech_radar_latam?sslmode=require
#   Supabase: postgres://postgres.xxx:pass@aws-0-xxx.pooler.supabase.com:6543/postgres
#   Railway:  postgres://postgres:pass@containers-us-xxx.railway.app:6543/railway
DATABASE_URL=postgres://postgres:postgres@localhost:5434/tech_radar_latam
PG_POOL_MAX=10
PG_SSL=false

# Auth (Google Identity Services)
# Crea el Client ID en https://console.cloud.google.com → APIs & Services → Credentials
# Tipo "Aplicación web", Authorized JavaScript origins:
#   http://localhost:5173 (y tu dominio en prod)
# Si GOOGLE_CLIENT_ID o AUTH_SESSION_SECRET quedan vacíos, el auth se
# desactiva: el chat IA queda abierto y no hay favoritos/RSVP.
GOOGLE_CLIENT_ID=
# Genera con: openssl rand -base64 48
AUTH_SESSION_SECRET=
# Cookie de sesión. Para dev local deja los valores por defecto.
# En producción con dominios distintos: SAMESITE=none, SECURE=true, DOMAIN=.tudominio.com
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=

# IA local opcional (Ollama)
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# IA cloud opcional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
